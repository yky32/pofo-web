# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Apex domain for studio subdomains (optional until DNS live)
# NEXT_PUBLIC_ROOT_DOMAIN=pofo.app

# Supabase (Phase 1 — required for auth + projects)
# Create a project at https://supabase.com then:
#   Project Settings → API → copy URL + anon key
#   SQL Editor → run supabase/schema.sql
# Full steps: supabase/SETUP.md
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional for Phase 1 (needed later for admin/jobs)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (batch upload — recommended for 300–800 photos)
# When all are set, uploads use presigned PUT → R2 (fallback: Supabase Storage)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=pofo
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# CORS on the bucket must allow PUT from your app origin (see docs/BATCH_UPLOAD.md)
