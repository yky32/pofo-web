# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Apex domain for studio subdomains (optional until DNS live)
# NEXT_PUBLIC_ROOT_DOMAIN=pofo.app

# Supabase (auth + DB + default private photo storage)
# Create a project at https://supabase.com then:
#   Project Settings → API → copy URL + anon key
#   SQL Editor → run supabase/schema.sql, then supabase/storage.sql
# Full steps: supabase/SETUP.md
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role (server only) — required for client share galleries to mint
# short-lived signed image URLs from the private shots bucket.
# Project Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: signs client unlock cookies for password-protected share links
# (falls back to service role key if unset)
# SHARE_GATE_SECRET=long-random-string

# Cloudflare R2 (optional scale-up — when set, uploads/reads switch automatically)
# Credentials alone enable private R2 + presigned PUT/GET (preferred).
# R2_PUBLIC_URL is optional (only if you want permanent public object URLs).
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=pofo
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# CORS on the bucket must allow PUT from your app origin (see docs/BATCH_UPLOAD.md)

# Resend (optional) — email client when share link is ready
# Without this, "Email client" opens the system mailto: compose window.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Pofo <onboarding@resend.dev>

# After base schema, also run (SQL Editor):
#   supabase/features-p1-p2.sql  — notes/flags, analytics, thumbs, bulk proof
#   supabase/features-p3.sql     — portfolio + original download window
